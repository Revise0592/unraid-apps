<?xml version="1.0"?>
<Container version="2">
  <Name>Grained</Name>
  <Repository>ghcr.io/revise0592/grained:latest</Repository>
  <Registry>ghcr.io/revise0592/grained</Registry>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://forums.unraid.net/topic/198330-support-grained-docker-application/</Support>
  <Project>https://github.com/Revise0592/grained</Project>
  <Overview>Self-hosted archive for film photography. Import lab scan zips, log metadata, browse in a lightbox, annotate frames.</Overview>
  <Category>MediaApp:Photos</Category>
  <WebUI>http://[IP]:[PORT:3000]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/Revise0592/unraid-apps/main/grained.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/Revise0592/grained/refs/heads/main/public/icons/icon-512.png</Icon>
  <Config Name="Web UI" Target="3000" Default="3000" Mode="tcp" Description="" Type="Port" Display="always" Required="false" Mask="false">3000</Config>
  <Config Name="Library" Target="/data" Default="/mnt/user/appdata/grained" Mode="rw" Description="" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/grained/</Config>
  <Config Name="AUTH_DISABLED" Target="AUTH_DISABLED" Default="false|true" Mode="" Description="Protect with an admin password." Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="UPLOAD_DIR" Target="UPLOAD_DIR" Default="/data/uploads" Mode="" Description="You don't need to change this." Type="Variable" Display="advanced-hide" Required="true" Mask="false">/data/uploads</Config>
  <Config Name="DATABASE_URL" Target="DATABASE_URL" Default="file:/data/grained.db" Mode="" Description="You don't need to change this." Type="Variable" Display="advanced-hide" Required="true" Mask="false">file:/data/grained.db</Config>
</Container>
